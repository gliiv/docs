{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "sequoia",
  "name": "Gliiv Docs",
  "api": {
    "baseUrl": "https://api.gliiv.com/v1"
  },
  "colors": {
    "primary": "#415a77",
    "light": "#647991",
    "dark": "#415a77"
  },
  "favicon": "/favicon.ico",
  "appearance": {
    "default": "system"
  },
  "fonts": {
    "family": "Nunito Sans"
  },
  "icons": {
    "library": "lucide"
  },
  "background": {
    "decoration": "windows"
  },
  "thumbnails": { "appearance": "light", "fonts": { "family": "Nunito Sans" } },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "root": "introduction",
            "pages": [
              "introduction",
              "quickstart"
            ]
          },
          {
            "group": "Campaign Management",
            "pages": [
              "manual-setup"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "pages": [
          "authentication",
          "send-sms"
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "contextual": {
    "options": [
      "claude",
      "chatgpt",
      "cursor",
      "copy",
      "view"
    ]
  },
  "footer": {
    "socials": {
      "website": "https://www.gliiv.com"
    }
  },
  "seo": {
    "indexing": "all"
  },
  "variables": {
    "api-url": "https://api.gliiv.com/v1"
  }
}
