{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "sequoia",
  "name": "Gliiv Docs",
  "api": {
    "baseUrl": "https://api.gliiv.com/v1"
  },
  "colors": {
    "primary": "#415a77",
    "light": "#415a77",
    "dark": "#647991"
  },
  "favicon": "/favicon.ico",
  "appearance": {
    "default": "system"
  },
  "fonts": {
    "family": "Nunito Sans"
  },
  "icons": {
    "library": "lucide"
  },
  "background": {
    "decoration": "gradient"
  },
  "thumbnails": { "appearance": "light", "fonts": { "family": "Nunito Sans" } },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Introduction",
            "pages": [
              "introduction",
              "quickstart"
            ]
          },
          {
            "group": "Campaign Management",
            "pages": [
              "manual-setup"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "pages": [
          "authentication",
          "send-sms"
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@gliiv.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "App",
      "href": "https://www.gliiv.com/app/auth/signin"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/gliiv",
      "linkedin": "https://linkedin.com/company/gliiv"
    }
  },
  "interaction": {
    "drilldown": false
  },
  "seo": {
    "indexing": "all"
  }
}
