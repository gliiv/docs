{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Gliiv",
  "colors": {
    "primary": "#415a77",
    "light": "#415a77",
    "dark": "#647991"
  },
  "favicon": "/favicon.png",
  "appearance": {
    "default": "system"
  },
  "fonts": {
    "family": "Nunito Sans"
  },
  "icons": {
    "library": "lucide"
  },
  "background": {
    "decoration": "gradient"
  },
  "thumbnails": { "appearance": "light", "fonts": { "family": "Nunito Sans" } },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "pages": [
          "product-overview",
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "development"
            ]
          },
          {
            "group": "Customization",
            "pages": [
              "essentials/settings",
              "essentials/navigation"
            ]
          },
          {
            "group": "Writing content",
            "pages": [
              "essentials/markdown",
              "essentials/code",
              "essentials/images",
              "essentials/reusable-snippets"
            ]
          },
          {
            "group": "AI tools",
            "pages": [
              "ai-tools/cursor",
              "ai-tools/claude-code",
              "ai-tools/windsurf"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "API documentation",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Endpoint examples",
            "pages": [
              "api-reference/endpoint/get",
              "api-reference/endpoint/create",
              "api-reference/endpoint/delete",
              "api-reference/endpoint/webhook"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@gliiv.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "App",
      "href": "https://www.gliiv.com/app/auth/signin"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/gliiv",
      "linkedin": "https://linkedin.com/company/gliiv"
    }
  },
  "interaction": {
    "drilldown": false
  },
  "seo": {
    "indexing": "all"
  }
}
