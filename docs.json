{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Gliiv",
  "colors": {
    "primary": "#415a77",
    "light": "#415a77",
    "dark": "#647991"
  },
  "favicon": "/favicon.ico",
  "appearance": {
    "default": "system"
  },
  "fonts": {
    "family": "Nunito Sans"
  },
  "icons": {
    "library": "lucide"
  },
  "background": {
    "decoration": "gradient"
  },
  "thumbnails": { "appearance": "light", "fonts": { "family": "Nunito Sans" } },
  "navigation": {
    "tabs": [
      {
        "tab": "Platform",
        "pages": [
          "product-overview",
          {
            "group": "The Message Center",
            "pages": [
              "index",
              "quickstart"
            ]
          },
          {
            "group": "Campaigns",
            "pages": [
              "essentials/settings",
              "essentials/navigation",
              "essentials/personalization-with-placeholders",
              "essentials/smart-scheduling-3-hour-rule",
              "essentials/understanding-campaign-status"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "API documentation",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "SMS API",
            "pages": [
              "api-reference/endpoint/get",
              "api-reference/endpoint/create",
              "api-reference/endpoint/delete",
              "api-reference/endpoint/webhook"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@gliiv.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "App",
      "href": "https://www.gliiv.com/app/auth/signin"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/gliiv",
      "linkedin": "https://linkedin.com/company/gliiv"
    }
  },
  "interaction": {
    "drilldown": false
  },
  "seo": {
    "indexing": "all"
  }
}
